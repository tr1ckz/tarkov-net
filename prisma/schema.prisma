generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  displayName   String
  gameName      String?
  tarkovProfileId String?
  tarkovProfileMode String?
  tarkovPveProfileId String?
  tarkovArenaProfileId String?
  pubgSteamUser String?
  pubgXboxUser  String?
  pubgPsnUser   String?
  pubgKakaoUser String?
  role          String     @default("USER")
  isSuspended   Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  favorites     Favorite[]
  inviteCodes   InviteCode[] @relation("InviteCreator")
  usedInvite    InviteCode?  @relation("InviteUsed", fields: [usedInviteId], references: [id])
  usedInviteId  String?    @unique
}

model InviteCode {
  id          String    @id @default(cuid())
  code        String    @unique
  createdById String
  isRevoked   Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  createdBy   User      @relation("InviteCreator", fields: [createdById], references: [id])
  usedBy      User?     @relation("InviteUsed")
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  itemId     String
  itemSlug   String
  itemName   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

model CachedItem {
  id             String             @id
  name           String
  shortName      String
  normalizedName String
  iconLink       String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  prices         CachedItemPrice[]
  snapshots      CachedPricePoint[]
}

model CachedItemPrice {
  id               String      @id @default(cuid())
  itemId           String
  gameMode         String
  avg24hPrice      Int?
  lastLowPrice     Int?
  basePrice        Int?
  bestTraderName   String?
  bestTraderPrice  Int?
  fetchedAt        DateTime    @default(now())
  item             CachedItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, gameMode])
  @@index([gameMode])
  @@index([itemId])
}

model CachedPricePoint {
  id           String      @id @default(cuid())
  itemId       String
  gameMode     String
  avg24hPrice  Int?
  lastLowPrice Int?
  capturedAt   DateTime    @default(now())
  item         CachedItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, gameMode, capturedAt])
  @@index([gameMode, capturedAt])
}

model CacheState {
  key              String    @id
  lastRefreshAt    DateTime?
  lastFullSyncAt   DateTime?
  lastSnapshotAt   DateTime?
  refreshInProgress Boolean  @default(false)
  refreshStartedAt DateTime?
  updatedAt        DateTime  @updatedAt
}

model CachedRaidIntel {
  id                  String   @id @default(cuid())
  gameMode            String   @unique
  reportedMap         String?
  reportedServer      String?
  reportedTime        String?
  reportedTimeType    String?
  reportCount         Int?
  goonsMap            String?
  goonsTimestamp      String?
  raidDurationMinutes Int?
  fetchedAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([gameMode, fetchedAt])
}

model PubgMapConfig {
  id              String   @id @default(cuid())
  mapSlug         String   @unique
  calibrationJson String?
  entitiesJson    String?
  legendJson      String?
  mapImageUrl     String?
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mapSlug])
}

model PubgActiveStreamer {
  twitchUserId    String   @id
  streamId        String   @unique
  userLogin       String   @unique
  userName        String
  gameId          String
  streamStartedAt DateTime
  title           String
  normalizedLogin String
  normalizedName  String
  indexedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([indexedAt])
  @@index([normalizedLogin])
  @@index([normalizedName])
}

model PubgStreamerProfile {
  twitchUserId     String   @id
  userLogin        String
  userName         String
  normalizedLogin  String
  normalizedName   String
  firstSeenAt      DateTime @default(now())
  lastSeenAt       DateTime @default(now())
  lastSeenLiveAt   DateTime?
  isLive           Boolean  @default(false)
  vodsEnabled      Boolean  @default(false)
  vodsCheckedAt    DateTime?
  lastVodAt        DateTime?
  lastStreamId     String?
  lastTitle        String?
  lastGameId       String?
  lastStreamStartAt DateTime?
  indexedAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([isLive])
  @@index([vodsEnabled])
  @@index([lastSeenAt])
  @@index([normalizedLogin])
  @@index([normalizedName])
}

model PubgLinkEvent {
  id                 String   @id @default(cuid())
  dedupeKey          String   @unique
  eventType          String
  pubgNameRaw        String
  pubgNameNormalized String
  twitchUserId       String
  twitchUserLogin    String
  twitchUserName     String
  twitchStreamId     String?
  twitchVideoId      String?
  shard              String?
  platform           String?
  encounterAt        DateTime?
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([pubgNameNormalized])
  @@index([twitchUserId])
  @@index([pubgNameNormalized, twitchUserId])
}

model PubgLinkRunLog {
  id                  String   @id @default(cuid())
  source              String
  status              String
  playerName          String?
  platform            String?
  requestedShard      String?
  resolvedShard       String?
  encountersFound     Int      @default(0)
  clipsReturned       Int      @default(0)
  activeIndexMatches  Int      @default(0)
  activeOverlapMatches Int     @default(0)
  directLoginMatches  Int      @default(0)
  searchChannelMatches Int     @default(0)
  vodMoments          Int      @default(0)
  channelsWithClips   Int      @default(0)
  linkEventsQueued    Int      @default(0)
  linkEventsPersisted Int      @default(0)
  errorMessage        String?
  metadataJson        String?
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([source])
  @@index([status])
}

model PubgStreamerIdentityLink {
  id                    String   @id @default(cuid())
  twitchUserId          String
  twitchUserLogin       String
  twitchUserName        String
  platform              String
  shard                 String
  pubgPlayerId          String
  pubgPlayerName        String
  pubgNameNormalized    String
  confidenceScore       Int      @default(0)
  confidenceReasonsJson String?
  source                String   @default("encounter_match")
  firstLinkedAt         DateTime @default(now())
  lastLinkedAt          DateTime @default(now())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([twitchUserId, platform], name: "twitchUserId_platform")
  @@index([pubgPlayerId])
  @@index([pubgNameNormalized])
  @@index([lastLinkedAt])
}

model PubgApiCallLog {
  id          String   @id @default(cuid())
  callType    String   // "player_lookup", "match_fetch", "telemetry_fetch"
  endpoint    String
  shard       String?
  statusCode  Int?
  durationMs  Int?
  success     Boolean
  triggeredBy String?  // "stream_online", "clips_route", "batch_linker", "indexer", "manual"
  errorMessage String?
  calledAt    DateTime @default(now())

  @@index([calledAt])
  @@index([callType])
  @@index([success])
  @@index([triggeredBy])
}

model PubgIdentityValidationQueue {
  id                      String   @id @default(cuid())
  identityLinkId          String
  status                  String   @default("queued") // queued | processing | completed | invalid | error
  attempts                Int      @default(0)
  maxAttempts             Int      @default(3)
  lastError               String?
  queuedAt                DateTime @default(now())
  startedAt               DateTime?
  completedAt             DateTime?
  nextAttemptAt           DateTime?
  lastValidatedPubgId     String?
  lastValidatedPubgName   String?
  lastValidatedShard      String?
  updatedAt               DateTime @updatedAt

  @@unique([identityLinkId])
  @@index([status, queuedAt])
  @@index([nextAttemptAt])
}

// Player name index built from PUBG /samples endpoint (hourly discovery worker)
model PubgKnownPlayer {
  id              String   @id @default(cuid())
  playerName      String
  playerNameLower String
  platform        String
  shard           String
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  seenCount       Int      @default(1)

  @@unique([playerName, platform, shard])
  @@index([playerNameLower])
  @@index([platform, shard])
  @@index([lastSeenAt])
}

model PubgStreamerMatch {
  id              String   @id @default(cuid())
  twitchUserId    String
  twitchUserLogin String
  twitchUserName  String
  platform        String
  shard           String
  pubgPlayerId    String
  pubgPlayerName  String
  matchId         String
  matchCreatedAt  DateTime?
  mapName         String?
  gameMode        String?
  telemetryUrl    String?
  source          String   @default("eventsub_stream_online")
  indexedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([twitchUserId, matchId], name: "twitchUserId_matchId")
  @@index([twitchUserId, indexedAt])
  @@index([matchCreatedAt])
}

model PubgStreamerVod {
  id              String   @id @default(cuid())
  twitchUserId    String
  twitchUserLogin String
  twitchUserName  String
  videoId         String   @unique
  title           String
  url             String
  thumbnailUrl    String?
  durationSeconds Int
  createdAtTwitch DateTime?
  publishedAtTwitch DateTime?
  indexedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([twitchUserId, createdAtTwitch])
}

model PubgMatchVodLink {
  id                String   @id @default(cuid())
  twitchUserId      String
  twitchUserLogin   String
  twitchUserName    String
  matchId           String
  videoId           String
  matchCreatedAt    DateTime?
  vodStartedAt      DateTime?
  vodOffsetSeconds  Int      @default(0)
  deltaSeconds      Int      @default(0)
  confidenceTag     String   @default("unknown")
  linkedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([twitchUserId, matchId], name: "twitchUserId_matchLink")
  @@index([videoId])
  @@index([linkedAt])
}

model PubgMatchInteraction {
  id                        String   @id @default(cuid())
  dedupeKey                 String   @unique
  twitchUserId              String
  twitchUserLogin           String
  twitchUserName            String
  streamerPubgPlayerId      String
  streamerPubgPlayerName    String
  counterpartyPubgPlayerId  String?
  counterpartyPubgNameRaw   String
  counterpartyPubgNameNormalized String
  interactionType           String
  interactionTitle          String
  platform                  String
  shard                     String
  matchId                   String
  matchCreatedAt            DateTime?
  encounterAt               DateTime?
  twitchVideoId             String
  vodOffsetSeconds          Int      @default(0)
  weapon                    String?
  distanceMeters            Int?
  mapTag                    String?
  gameModeTag               String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([counterpartyPubgNameNormalized])
  @@index([counterpartyPubgPlayerId])
  @@index([platform, shard])
  @@index([encounterAt])
  @@index([twitchUserId, createdAt])
}
