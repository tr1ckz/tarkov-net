<?xml version="1.0"?>
<Container version="2">
  <Name>TARKOV NET</Name>
  <Repository>ghcr.io/tr1ckz/tarkov-net:latest</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/tr1ckz/tarkov-net</Support>
  <Project>https://github.com/tr1ckz/tarkov-net</Project>
  <Overview>Dark-web styled Escape from Tarkov market intelligence platform with auth, watchlists, and live PvP/PvE/Arena player stats.</Overview>
  <Category>Network:Web</Category>
  <WebUI>http://[IP]:[PORT:3000]</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/tr1ckz/tarkov-net/main/unraid/tarkov-net.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/tr1ckz/tarkov-net/main/public/favicon.ico</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>TARKOV NET Unraid container template.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>3000</HostPort>
        <ContainerPort>3000</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Config Name="Appdata" Target="/app/data" Default="/mnt/user/appdata/tarkov-net/data" Mode="rw" Description="Persistent SQLite data directory on cache for low-latency I/O. Do NOT mount /app/prisma." Type="Path" Display="always" Required="true" Mask="false"/>
  <Config Name="NEXTAUTH_URL" Target="NEXTAUTH_URL" Default="http://YOUR_UNRAID_IP:3000" Mode="" Description="Public URL for NextAuth callbacks" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="NEXTAUTH_SECRET" Target="NEXTAUTH_SECRET" Default="change-me" Mode="" Description="Long random secret for session encryption" Type="Variable" Display="always" Required="true" Mask="true"/>
  <Config Name="DATABASE_URL" Target="DATABASE_URL" Default="file:/app/data/games.db?connection_limit=1" Mode="" Description="SQLite database path inside the container (single connection to reduce lock timeouts)" Type="Variable" Display="always" Required="true" Mask="false"/>
  <Config Name="CACHE_REFRESH_SECRET" Target="CACHE_REFRESH_SECRET" Default="" Mode="" Description="Optional token for /api/cache/refresh" Type="Variable" Display="advanced" Required="false" Mask="true"/>
</Container>
